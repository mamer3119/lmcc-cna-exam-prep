{
  "name": "lmcc-cna-exam-prep",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node scripts/clean.mjs && next dev",
    "dev:direct": "node ./node_modules/next/dist/bin/next dev",
    "prebuild": "node scripts/sync-skills.mjs",
    "build": "next build",
    "postbuild": "node scripts/fix-export-paths.mjs && node scripts/verify-export.mjs",
    "start": "next start",
    "test": "vitest run",
    "sync:skills": "node scripts/sync-skills.mjs",
    "clean": "node scripts/clean.mjs"
  },
  "dependencies": {
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
