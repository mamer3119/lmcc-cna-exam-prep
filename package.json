{
  "name": "lmcc-cna-exam-prep",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "predev": "node scripts/check-node-lts.cjs && node scripts/kill-dev-port.mjs 3005 && node scripts/dev-preflight.mjs && node scripts/sync-skills.mjs",
    "dev": "next dev --port 3005",
    "dev:clean": "node scripts/kill-dev-port.mjs 3005 && node scripts/clean.mjs && node scripts/sync-skills.mjs && node scripts/dev-preflight.mjs && next dev --port 3005",
    "dev:direct": "node ./node_modules/next/dist/bin/next dev",
    "prebuild": "node scripts/check-node-lts.cjs && node scripts/dev-preflight.mjs && node scripts/sync-skills.mjs && node scripts/sync-brand-assets.mjs && pnpm test",
    "build": "next build",
    "postbuild": "node scripts/fix-export-paths.mjs && node scripts/verify-export.mjs",
    "start": "next start",
    "test": "vitest run",
    "verify:export": "node scripts/verify-export.mjs",
    "verify:live": "node scripts/probe-live-export.mjs",
    "probe:dev-skills": "node scripts/probe-dev-skills.mjs",
    "sync:skills": "node scripts/sync-skills.mjs",
    "import:final-pass": "node scripts/import-final-pass.mjs",
    "import:exemplar-s01-s04": "node scripts/import-exemplar-s01-s04.mjs",
    "merge:final-pass": "node scripts/merge-final-pass.mjs",
    "normalize:boilerplate": "node scripts/normalize-master-db.mjs && node scripts/sync-skills.mjs",
    "sync:brand": "node scripts/sync-brand-assets.mjs",
    "clean": "node scripts/clean.mjs",
    "check:node-lts": "node scripts/check-node-lts.cjs"
  },
  "dependencies": {
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "24.7.2",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
